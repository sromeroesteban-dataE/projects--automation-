        "jsCode": "const response = $input.item.json;\nconst candidate = $('🔧 Extraer candidatos del response').all()[$itemIndex].json;\n\nconst content = response.content?.[0]?.text || '{}';\nconst cleaned = content.replace(/```json|```/g, '').trim();\n\nlet scoring = {};\ntry {\n  scoring = JSON.parse(cleaned);\n} catch(e) {\n  scoring = {\n    score: 0,\n    matched_keywords: [],\n    reasoning: 'Parse error: ' + e.message,\n    urgency: 'low',\n    recommended_action: 'discard',\n    adtech_relevance: 'low'\n  };\n}\n\nconst safeReasoning = (scoring.reasoning || '').replace(/'/g, \"''\");\nconst safeKeywords = (scoring.matched_keywords || []).join(', ').replace(/'/g, \"''\");\n\nreturn {\n  json: {\n    ...candidate,\n    score: scoring.score || 0,\n    matched_keywords: safeKeywords,\n    reasoning: safeReasoning,\n    urgency: scoring.urgency || 'low',\n    recommended_action: scoring.recommended_action || 'discard',\n    adtech_relevance: scoring.adtech_relevance || 'low',\n    scored_at: new Date().toISOString()\n  }\n};"
