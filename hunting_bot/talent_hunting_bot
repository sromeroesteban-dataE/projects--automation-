      "parameters": {
        "jsCode": "const items = $input.all();\nconst vacancy = $('🔁 Split · una ejecución por vacante').first().json;\n\nconst candidates = [];\n\nfor (const item of items) {\n  const person = item.json;\n  \n  if (!person.linkedinProfileUrl) continue;\n\n  candidates.push({\n    json: {\n      full_name: person.fullName || '',\n      linkedin_url: person.linkedinProfileUrl,\n      current_title: person.headline || '',\n      current_company: person.company || '',\n      current_company2: person.company2 || '',\n      position_raw: person.headline || '',\n      city: person.location || '',\n      country: vacancy.location,\n      email: null,\n      open_to_work: false,\n      additional_info: person.additionalInfo || '',\n      job_title: person.jobTitle || '',\n      job_title2: person.jobTitle2 || '',\n      skills: [],\n      years_experience: 3,\n      vacancy_id: vacancy.vacancy_id,\n      vacancy_title: vacancy.title,\n      vacancy_location: vacancy.location,\n      vacancy_description: vacancy.description,\n      unique_key: person.linkedinProfileUrl,\n      searched_at: new Date().toISOString()\n    }\n  });\n}\n\nreturn candidates.length > 0 \n  ? candidates \n  : [{ json: { skip: true, reason: 'No profiles returned' } }];"
      },
