    {
      "parameters": {
        "jsCode": "const rawResponse = $input.first().json;\nlet vacList = [];\nif (Array.isArray(rawResponse)) {\n  vacList = rawResponse[0]?.data || [];\n} else if (rawResponse.data) {\n  vacList = rawResponse.data;\n} else {\n  vacList = [rawResponse];\n}\n\nvacList = vacList.filter(v => v.state === 'opened');\n\nconst locationMap = {\n  'Brazil': { name: 'Brazil', geo_id: '106057199' },\n  'Brasil': { name: 'Brazil', geo_id: '106057199' },\n  'Argentina': { name: 'Argentina', geo_id: '100446943' },\n  'Mexico': { name: 'Mexico', geo_id: '103323778' },\n  'México': { name: 'Mexico', geo_id: '103323778' },\n  'Colombia': { name: 'Colombia', geo_id: '100876405' },\n  'Uruguay': { name: 'Uruguay', geo_id: '100867946' }\n};\n\nconst adtechCompanies = [\n  'groupm.com', 'wpp.com', 'publicismedia.com', 'publicis.com',\n  'dentsu.com', 'havas.com', 'omnicommediagroup.com', 'mediabrands.com',\n  'thetradedesk.com', 'integralads.com', 'doubleverify.com',\n  'xandr.com', 'teads.com', 'adsmovil.com', 'imslatam.com'\n];\n\nconst results = [];\n\nfor (const v of vacList) {\n  const title = (v.title || '').trim();\n  const locationData = locationMap[v.location?.name] || { name: v.location?.name || 'Argentina', geo_id: '100446943' };\n\n  const descriptionClean = (v.description || '')\n    .replace(/<[^>]*>/g, ' ')\n    .replace(/&amp;/g, '&')\n    .replace(/&nbsp;/g, ' ')\n    .replace(/&lt;/g, '<')\n    .replace(/&gt;/g, '>')\n    .replace(/\\s+/g, ' ')\n    .trim()\n    .substring(0, 4000);\n\n  results.push({\n    json: {\n      vacancy_id: v.id,\n      title: title,\n      location: locationData.name,\n      geo_id: locationData.geo_id,\n      description: v.description || '',\n      description_clean: descriptionClean,\n      target_companies: adtechCompanies,\n      processed_at: new Date().toISOString()\n    }\n  });\n}\n\nreturn results;"
      },
