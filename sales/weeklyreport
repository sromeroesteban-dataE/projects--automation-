    {
      "parameters": {
        "jsCode": "// ============================================================\n// DAX QUERIES - Based on actual Power BI model\n// ============================================================\n// Tables: Calendar, UNION_TARGET_VS_SALES, VIEW_DEALS_SALES\n// Measures: [Target], [Revenue], [ExpectRevenue], [Booking]\n// Market column: UNION_TARGET_VS_SALES[REGION]\n// Date filters: Calendar[Año], Calendar[Trimestre], Calendar[MesNumerico]\n// ============================================================\n\nconst input = $input.first().json;\nconst year = input.currentYear;\nconst month = input.currentMonth;\nconst quarter = `Q${input.currentQuarter}`;\n\nfunction buildQuery(name, dax) {\n  return {\n    queryName: name,\n    token: input.token,\n    apiUrl: input.apiUrl,\n    recipients: input.recipients,\n    currentYear: input.currentYear,\n    currentMonth: input.currentMonth,\n    quarterLabel: input.quarterLabel,\n    monthLabel: input.monthLabel,\n    queryPayload: JSON.stringify({\n      queries: [{ query: dax }],\n      serializerSettings: { includeNulls: true }\n    })\n  };\n}\n\n// -------------------------------------------------------\n// QUERY 1: KPIs by Market - Quarter to Date\n// Uses the existing measures [Target], [Revenue],\n// [ExpectRevenue], [Booking] with Calendar filters\n// for the current year and quarter.\n// UNION_TARGET_VS_SALES[REGION] is the market dimension\n// that drives Target via TREATAS.\n// -------------------------------------------------------\nconst q1_qtd = buildQuery('kpi_qtd', `\n  EVALUATE\n  SUMMARIZECOLUMNS(\n    UNION_TARGET_VS_SALES[REGION],\n    TREATAS({${year}}, 'Calendar'[Año]),\n    TREATAS({\"${quarter}\"}, 'Calendar'[Trimestre]),\n    \"Target\", [Target],\n    \"Revenue\", [Revenue],\n    \"ExpectedRevenue\", [ExpectRevenue],\n    \"Bookings\", [Booking]\n  )\n  ORDER BY UNION_TARGET_VS_SALES[REGION]\n`);\n\n// -------------------------------------------------------\n// QUERY 2: KPIs by Market - Month to Date\n// Same measures but filtered to current month.\n// -------------------------------------------------------\nconst q2_mtd = buildQuery('kpi_mtd', `\n  EVALUATE\n  SUMMARIZECOLUMNS(\n    UNION_TARGET_VS_SALES[REGION],\n    TREATAS({${year}}, 'Calendar'[Año]),\n    TREATAS({${month}}, 'Calendar'[MesNumerico]),\n    \"Target\", [Target],\n    \"Revenue\", [Revenue],\n    \"ExpectedRevenue\", [ExpectRevenue],\n    \"Bookings\", [Booking]\n  )\n  ORDER BY UNION_TARGET_VS_SALES[REGION]\n`);\n\n// -------------------------------------------------------\n// QUERY 3: Campaign detail - Month to Date (ongoing)\n// Pulls deal-level detail for campaigns that are NOT\n// yet closed (LAST_EVENT != CIERRES_GANADOS and\n// != CIERRES_PERDIDOS) filtered to current month.\n// Adjust the LAST_EVENT filter as needed.\n// -------------------------------------------------------\nconst q3_campaigns = buildQuery('campaigns', `\n  EVALUATE\n  VAR AllDeals = \n    DISTINCT(VIEW_DEALS_SALES[DEAL_ID])\n  VAR DetalleDeals =\n    ADDCOLUMNS(\n      AllDeals,\n      \"DealName\", LOOKUPVALUE(VIEW_DEALS_SALES[DEALNAME], VIEW_DEALS_SALES[DEAL_ID], [DEAL_ID]),\n      \"Advertiser\", LOOKUPVALUE(VIEW_DEALS_SALES[NOMBRE_ANUNCIANTE], VIEW_DEALS_SALES[DEAL_ID], [DEAL_ID]),\n      \"Market\", LOOKUPVALUE(VIEW_DEALS_SALES[MERCADOS], VIEW_DEALS_SALES[DEAL_ID], [DEAL_ID]),\n      \"Revenue\", CALCULATE([Revenue], TREATAS({[DEAL_ID]}, VIEW_DEALS_SALES[DEAL_ID]), TREATAS({${year}}, 'Calendar'[Año]), TREATAS({${month}}, 'Calendar'[MesNumerico])),\n      \"ExpectedRevenue\", CALCULATE([ExpectRevenue], TREATAS({[DEAL_ID]}, VIEW_DEALS_SALES[DEAL_ID]), TREATAS({${year}}, 'Calendar'[Año]), TREATAS({${month}}, 'Calendar'[MesNumerico]))\n    )\n  RETURN\n    FILTER(DetalleDeals, [Revenue] <> 0 || [ExpectedRevenue] <> 0)\n  ORDER BY [Market], [Revenue] DESC\n`);\n\nconst q4_bookings = buildQuery('bookings_detail', `\n  EVALUATE\n  VAR AllDeals = \n    DISTINCT(VIEW_DEALS_SALES[DEAL_ID])\n  VAR DetalleDeals =\n    ADDCOLUMNS(\n      AllDeals,\n      \"DealName\", LOOKUPVALUE(VIEW_DEALS_SALES[DEALNAME], VIEW_DEALS_SALES[DEAL_ID], [DEAL_ID]),\n      \"Advertiser\", LOOKUPVALUE(VIEW_DEALS_SALES[NOMBRE_ANUNCIANTE], VIEW_DEALS_SALES[DEAL_ID], [DEAL_ID]),\n      \"Market\", LOOKUPVALUE(VIEW_DEALS_SALES[MERCADOS], VIEW_DEALS_SALES[DEAL_ID], [DEAL_ID]),\n      \"Bookings\", CALCULATE([Booking], TREATAS({[DEAL_ID]}, VIEW_DEALS_SALES[DEAL_ID]), TREATAS({${year}}, 'Calendar'[Año]), TREATAS({${month}}, 'Calendar'[MesNumerico]))\n    )\n  RETURN\n    FILTER(DetalleDeals, [Bookings] <> 0)\n  ORDER BY [Market], [Bookings] DESC\n`);\n\nreturn [\n  { json: q1_qtd },\n  { json: q2_mtd },\n  { json: q3_campaigns },\n  { json: q4_bookings }\n];"
      },
