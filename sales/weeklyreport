    {
      "parameters": {
        "jsCode": "// ============================================================\n// AGGREGATE ALL RESULTS & BUILD HTML EMAIL\n// ============================================================\n\nconst items = $input.all();\nconst data = {};\nlet meta = {};\n\nfor (const item of items) {\n  const { queryName, rows, ...rest } = item.json;\n  data[queryName] = rows || [];\n  meta = rest;\n}\n\n// ---- Helper functions ----\nfunction fmt(n) {\n  if (n === null || n === undefined || isNaN(n)) return '$0';\n  return '$' + Math.round(Number(n)).toLocaleString('en-US');\n}\n\nfunction pct(actual, target) {\n  if (!target || target === 0) return '—';\n  return ((actual / target) * 100).toFixed(1) + '%';\n}\n\n// ---- Process KPI data ----\nconst qtdRows = data.kpi_qtd || [];\nconst mtdRows = data.kpi_mtd || [];\nconst campaignRows = data.campaigns || [];\n\n// Get unique markets - EXCLUDE ROW and blank\nconst markets = [...new Set([\n  ...qtdRows.map(r => r['UNION_TARGET_VS_SALES[REGION]']),\n  ...mtdRows.map(r => r['UNION_TARGET_VS_SALES[REGION]'])\n])].filter(m => m && m !== 'ROW').sort();\n\n// Helper to get row\nfunction getRow(rows, market) {\n  return rows.find(r => r['UNION_TARGET_VS_SALES[REGION]'] === market) || {};\n}\n\nfunction sumField(rows, field) {\n  return rows\n    .filter(r => r['UNION_TARGET_VS_SALES[REGION]'] && r['UNION_TARGET_VS_SALES[REGION]'] !== 'ROW')\n    .reduce((acc, r) => acc + (Number(r[field]) || 0), 0);\n}\n\n// Global totals (excluding ROW and blank)\nconst globalQTD = {\n  target: sumField(qtdRows, '[Target]'),\n  revenue: sumField(qtdRows, '[Revenue]'),\n  expected: sumField(qtdRows, '[ExpectedRevenue]'),\n  bookings: sumField(qtdRows, '[Bookings]')\n};\n\nconst globalMTD = {\n  target: sumField(mtdRows, '[Target]'),\n  revenue: sumField(mtdRows, '[Revenue]'),\n  expected: sumField(mtdRows, '[ExpectedRevenue]'),\n  bookings: sumField(mtdRows, '[Bookings]')\n};\n\n// ---- Build HTML ----\nconst reportDate = new Date().toISOString().split('T')[0];\nconst { quarterLabel, monthLabel, currentYear } = meta;\n\nconst styles = `\n<style>\n  body { font-family: Arial, Helvetica, sans-serif; color: #1f2937; margin: 0; padding: 0; background: #f9fafb; }\n  .container { max-width: 850px; margin: 0 auto; padding: 24px; }\n  .header { background: linear-gradient(135deg, #7c3aed, #8b5cf6, #6366f1); color: white; padding: 28px 32px; border-radius: 16px; margin-bottom: 28px; }\n  .header h1 { margin: 0; font-size: 24px; font-weight: 700; }\n  .header p { margin: 8px 0 0; opacity: 0.9; font-size: 14px; }\n  .kpi-row-title { font-size: 14px; font-weight: 600; color: #7c3aed; margin: 20px 0 10px; text-transform: uppercase; letter-spacing: 0.5px; }\n  .kpi-cards { display: flex; gap: 12px; margin-bottom: 8px; flex-wrap: wrap; }\n  .kpi-card { flex: 1; min-width: 180px; background: white; border-radius: 12px; padding: 16px; border: 1px solid #e5e7eb; }\n  .kpi-card .label { font-size: 11px; text-transform: uppercase; color: #6b7280; letter-spacing: 0.5px; margin-bottom: 4px; }\n  .kpi-card .value { font-size: 26px; font-weight: 700; color: #1f2937; }\n  .kpi-card .sub { font-size: 13px; margin-top: 4px; }\n  .kpi-card .pct-highlight { font-weight: 700; font-size: 14px; color: #1f2937; }\n  .section { margin-bottom: 28px; }\n  .section h2 { font-size: 16px; color: #7c3aed; margin: 0 0 14px; padding-bottom: 8px; border-bottom: 2px solid #ede9fe; }\n  table { width: 100%; border-collapse: collapse; font-size: 12px; background: white; border-radius: 8px; overflow: hidden; border: 1px solid #e5e7eb; }\n  th { background: #f5f3ff; color: #5b21b6; text-align: right; padding: 8px 10px; font-weight: 600; font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; }\n  th:first-child { text-align: left; }\n  td { padding: 8px 10px; text-align: right; border-top: 1px solid #f3f4f6; }\n  td:first-child { text-align: left; font-weight: 500; color: #374151; }\n  tr.global-row { background: #faf5ff; }\n  tr.global-row td { font-weight: 700; border-top: 2px solid #ddd6fe; border-bottom: 2px solid #ddd6fe; }\n  .footer { margin-top: 36px; padding-top: 16px; border-top: 1px solid #e5e7eb; font-size: 11px; color: #9ca3af; text-align: center; }\n</style>`;\n\n// ---- KPI Cards (same as before) ----\nconst kpiRow1 = `\n<div class=\"kpi-row-title\">${quarterLabel} — Quarter to Date</div>\n<div class=\"kpi-cards\">\n  <div class=\"kpi-card\">\n    <div class=\"label\">Target ${quarterLabel}</div>\n    <div class=\"value\">${fmt(globalQTD.target)}</div>\n  </div>\n  <div class=\"kpi-card\">\n    <div class=\"label\">Revenue ${quarterLabel}</div>\n    <div class=\"value\">${fmt(globalQTD.revenue)}</div>\n    <div class=\"sub\"><span class=\"pct-highlight\">${pct(globalQTD.revenue, globalQTD.target)}</span> vs Target</div>\n  </div>\n  <div class=\"kpi-card\">\n    <div class=\"label\">Expected Revenue ${quarterLabel}</div>\n    <div class=\"value\">${fmt(globalQTD.expected)}</div>\n  </div>\n  <div class=\"kpi-card\">\n    <div class=\"label\">Bookings ${quarterLabel}</div>\n    <div class=\"value\">${fmt(globalQTD.bookings)}</div>\n  </div>\n</div>`;\n\nconst kpiRow2 = `\n<div class=\"kpi-row-title\">${monthLabel} — Month to Date</div>\n<div class=\"kpi-cards\">\n  <div class=\"kpi-card\">\n    <div class=\"label\">Target ${monthLabel}</div>\n    <div class=\"value\">${fmt(globalMTD.target)}</div>\n  </div>\n  <div class=\"kpi-card\">\n    <div class=\"label\">Revenue ${monthLabel}</div>\n    <div class=\"value\">${fmt(globalMTD.revenue)}</div>\n    <div class=\"sub\"><span class=\"pct-highlight\">${pct(globalMTD.revenue, globalMTD.target)}</span> vs Target</div>\n  </div>\n  <div class=\"kpi-card\">\n    <div class=\"label\">Expected Revenue ${monthLabel}</div>\n    <div class=\"value\">${fmt(globalMTD.expected)}</div>\n  </div>\n  <div class=\"kpi-card\">\n    <div class=\"label\">Bookings ${monthLabel}</div>\n    <div class=\"value\">${fmt(globalMTD.bookings)}</div>\n  </div>\n</div>`;\n\n// ---- KPI Table - REORDERED: Q columns first, then Month columns ----\nfunction kpiRow(label, qtd, mtd, isGlobal = false) {\n  const cls = isGlobal ? ' class=\"global-row\"' : '';\n  return `<tr${cls}>\n    <td>${label}</td>\n    <td>${fmt(qtd.target)}</td>\n    <td>${fmt(qtd.revenue)} <span style=\"font-weight:700;font-size:11px;margin-left:4px;\">(${pct(qtd.revenue, qtd.target)})</span></td>\n    <td>${fmt(qtd.expected)}</td>\n    <td>${fmt(qtd.bookings)}</td>\n    <td>${fmt(mtd.target)}</td>\n    <td>${fmt(mtd.revenue)} <span style=\"font-weight:700;font-size:11px;margin-left:4px;\">(${pct(mtd.revenue, mtd.target)})</span></td>\n    <td>${fmt(mtd.expected)}</td>\n    <td>${fmt(mtd.bookings)}</td>\n  </tr>`;\n}\n\nlet marketRows = kpiRow('GLOBAL', globalQTD, globalMTD, true);\nfor (const m of markets) {\n  const qtd = getRow(qtdRows, m);\n  const mtd = getRow(mtdRows, m);\n  const mQTD = {\n    target: Number(qtd['[Target]']) || 0,\n    revenue: Number(qtd['[Revenue]']) || 0,\n    expected: Number(qtd['[ExpectedRevenue]']) || 0,\n    bookings: Number(qtd['[Bookings]']) || 0\n  };\n  const mMTD = {\n    target: Number(mtd['[Target]']) || 0,\n    revenue: Number(mtd['[Revenue]']) || 0,\n    expected: Number(mtd['[ExpectedRevenue]']) || 0,\n    bookings: Number(mtd['[Bookings]']) || 0\n  };\n  marketRows += kpiRow(m, mQTD, mMTD);\n}\n\nconst kpiTable = `\n<table>\n  <thead>\n    <tr>\n      <th rowspan=\"2\">Market</th>\n      <th colspan=\"4\" style=\"text-align:center;background:#ede9fe;\">${quarterLabel} ${currentYear}</th>\n      <th colspan=\"4\" style=\"text-align:center;background:#e0f2fe;color:#0369a1;\">${monthLabel} ${currentYear}</th>\n    </tr>\n    <tr>\n      <th>Target</th>\n      <th>Revenue</th>\n      <th>Exp. Rev</th>\n      <th>Bookings</th>\n      <th style=\"background:#e0f2fe;color:#0369a1;\">Target</th>\n      <th style=\"background:#e0f2fe;color:#0369a1;\">Revenue</th>\n      <th style=\"background:#e0f2fe;color:#0369a1;\">Exp. Rev</th>\n      <th style=\"background:#e0f2fe;color:#0369a1;\">Bookings</th>\n    </tr>\n  </thead>\n  <tbody>${marketRows}</tbody>\n</table>`;\n\n// ---- Campaign CSV attachment ----\nlet campaignCsv = 'Deal ID,Deal Name,Advertiser,Market,Revenue,Expected Revenue\\n';\nif (campaignRows.length > 0) {\n  for (const c of campaignRows) {\n    const dealId = c['VIEW_DEALS_SALES[DEAL_ID]'] || '';\n    const dealName = (c['[DealName]'] || '').replace(/,/g, ';');\n    const advertiser = (c['[Advertiser]'] || '').replace(/,/g, ';');\n    const market = c['[Market]'] || '';\n    const revenue = Number(c['[Revenue]']) || 0;\n    const expected = Number(c['[ExpectedRevenue]']) || 0;\n    campaignCsv += `${dealId},\"${dealName}\",\"${advertiser}\",${market},${revenue.toFixed(2)},${expected.toFixed(2)}\\n`;\n  }\n}\n\nconst csvBase64 = Buffer.from(campaignCsv, 'utf-8').toString('base64');\n\n\nconst bookingRows = data.bookings_detail || [];\n\nlet bookingsCsv = 'Deal ID,Deal Name,Advertiser,Market,Bookings\\n';\nif (bookingRows.length > 0) {\n  for (const c of bookingRows) {\n    const dealId = c['VIEW_DEALS_SALES[DEAL_ID]'] || '';\n    const dealName = (c['[DealName]'] || '').replace(/,/g, ';');\n    const advertiser = (c['[Advertiser]'] || '').replace(/,/g, ';');\n    const market = c['[Market]'] || '';\n    const bookings = Number(c['[Bookings]']) || 0;\n    bookingsCsv += `${dealId},\"${dealName}\",\"${advertiser}\",${market},${bookings.toFixed(2)}\\n`;\n  }\n}\n\nconst bookingsCsvBase64 = Buffer.from(bookingsCsv, 'utf-8').toString('base64');\n// ---- Assemble Email ----\nconst html = `<!DOCTYPE html>\n<html><head><meta charset=\"utf-8\">${styles}</head>\n<body>\n<div class=\"container\">\n  <div class=\"header\">\n    <h1>Weekly Sales Report</h1>\n    <p>{{COMPANY_NAME}} · ${quarterLabel} ${currentYear} · Week of ${reportDate}</p>\n  </div>\n\n  ${kpiRow1}\n  ${kpiRow2}\n\n  <div class=\"section\" style=\"margin-top:24px;\">\n    <h2>KPI Summary by Market</h2>\n    ${kpiTable}\n  </div>\n\n  <div class=\"footer\">\n    <p>Auto-generated from Power BI Sales Intelligence Dashboard · ${reportDate}</p>\n    <p>Ongoing campaigns detail attached as CSV.</p>\n  </div>\n</div>\n</body></html>`;\n\nreturn [{\n  json: {\n    html,\n    recipients: meta.recipients,\n    subject: `Weekly Sales Report — {{COMPANY_NAME}} — ${quarterLabel} ${currentYear} — ${reportDate}`,\n    campaignCsvBase64: csvBase64,\n    campaignFileName: `ongoing_campaigns_${monthLabel}_${currentYear}.csv`,\n    bookingsCsvBase64: bookingsCsvBase64,\n    bookingsFileName: `bookings_detail_${monthLabel}_${currentYear}.csv`\n  }\n}];"
      },
