      "parameters": {
        "jsCode": "// ============================================================\n// CONFIGURATION - Edit these values\n// ============================================================\nconst WORKSPACE_ID = '{{POWERBI_WORKSPACE_ID}}';\nconst DATASET_ID = '{{POWERBI_DATASET_ID}}';\nconst RECIPIENTS ='{{REPORT_RECIPIENTS}}';\n\n\n// ============================================================\n// DATE CALCULATIONS\n// ============================================================\nconst now = new Date();\nconst currentYear = now.getFullYear();\nconst currentMonth = now.getMonth() + 1;\nconst currentQuarter = Math.ceil(currentMonth / 3);\n\n// Quarter label (Q1, Q2, etc.)\nconst quarterLabel = `Q${currentQuarter}`;\n\n// Month name in Spanish\nconst monthNames = ['', 'Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio',\n  'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];\nconst monthLabel = monthNames[currentMonth];\n\nconst token = $input.first().json.access_token;\nconst apiUrl = `https://api.powerbi.com/v1.0/myorg/groups/${WORKSPACE_ID}/datasets/${DATASET_ID}/executeQueries`;\n\nreturn [{\n  json: {\n    token,\n    apiUrl,\n    recipients: RECIPIENTS,\n    currentYear,\n    currentMonth,\n    currentQuarter,\n    quarterLabel,\n    monthLabel\n  }\n}];"
      },
      "id": "8ee7553e-d781-4803-bd19-633d9714787b",
      "name": "Config & Date Calc",
