      "parameters": {
        "jsCode": "// Parse DAX query result\nconst response = $input.first().json;\nconst loopItem = $('Loop Queries').item.json;\n\nlet rows = [];\ntry {\n  rows = response.results[0].tables[0].rows;\n} catch (e) {\n  rows = [];\n}\n\nreturn [{\n  json: {\n    queryName: loopItem.queryName,\n    rows,\n    token: loopItem.token,\n    apiUrl: loopItem.apiUrl,\n    recipients: loopItem.recipients,\n    currentYear: loopItem.currentYear,\n    currentMonth: loopItem.currentMonth,\n    quarterLabel: loopItem.quarterLabel,\n    monthLabel: loopItem.monthLabel\n  }\n}];"
      },
      "id": "e5c5462c-f3b9-4b27-b6b0-0f4e1cfd8c16",
      "name": "Parse DAX Result",
      "type": "n8n-nodes-base.code",
